{
    "name": "yourusername/twitter-oauth-v2",
    "description": "A robust PHP library for handling Twitter OAuth 2.0 authentication and API requests.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Your Name",
            "email": "youremail@example.com",
            "homepage": "https://yourwebsite.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "TwitterOAuthV2\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TwitterOAuthV2\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}